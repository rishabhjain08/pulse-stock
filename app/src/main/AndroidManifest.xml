<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Android 16: required to promote notification to the Now Bar -->
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PulseStock">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustNothing">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Long-pressing the QS tile shows a native "Open app" link to this activity. -->
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE_PREFERENCES" />
            </intent-filter>
            <!-- Splitwise OAuth callback deep link -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="pulsestock" android:host="splitwise" android:pathPrefix="/callback" />
            </intent-filter>
        </activity>

        <!--
            PulseHUDService: foreground service that owns the WebSocket connection
            and the WindowManager overlay.
            foregroundServiceType="specialUse" is required for overlay-style services
            on Android 14+ that don't fit a standard type.
        -->
        <service
            android:name=".PulseHUDService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <!-- Required justification for Play Store review -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Real-time stock price HUD displayed as a system overlay" />
        </service>

        <!--
            PulseTileService: the Quick Settings tile that triggers the HUD.
        -->
        <service
            android:name=".PulseTileService"
            android:icon="@drawable/ic_pulse_tile"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!--
            Disable profileinstaller's auto-init. ProfileVerifier crashes on Samsung Android 16
            with NoSuchMethodError on PackageManager.PackageInfoFlags.of(long). We don't use
            baseline profiles so there is no benefit to having this run.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="@integer/androidx_startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
